<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>URL Range Opener</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', sans-serif;
    background: #0f0f0f;
    color: #e8e8e8;
    min-height: 100vh;
    padding: 2rem;
  }
  h1 {
    font-size: 1.4rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.4rem;
    letter-spacing: -0.3px;
  }
  .subtitle {
    font-size: 13px;
    color: #666;
    margin-bottom: 2rem;
  }
  .card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
    max-width: 720px;
  }
  label {
    display: block;
    font-size: 12px;
    color: #888;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  input[type=text], input[type=number] {
    width: 100%;
    background: #111;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 10px 14px;
    color: #e8e8e8;
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  input:focus { border-color: #555; }
  input::placeholder { color: #444; }
  .row { display: flex; gap: 12px; margin-top: 1rem; }
  .row > div { flex: 1; }
  .btn-row { display: flex; gap: 10px; margin-top: 1.25rem; flex-wrap: wrap; }
  button {
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all 0.15s;
  }
  .btn-primary {
    background: #e8e8e8;
    color: #0f0f0f;
  }
  .btn-primary:hover { background: #fff; }
  .btn-secondary {
    background: transparent;
    border: 1px solid #333;
    color: #e8e8e8;
  }
  .btn-secondary:hover { border-color: #555; background: #1f1f1f; }
  .btn-danger {
    background: transparent;
    border: 1px solid #4a1a1a;
    color: #e05a5a;
  }
  .btn-danger:hover { background: #2a0f0f; }

  #status {
    font-size: 13px;
    color: #666;
    margin-top: 1rem;
    display: none;
  }
  #status span { color: #aaa; }

  .link-list {
    max-height: 420px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 1rem;
  }
  .link-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    background: #111;
    border: 1px solid #222;
    border-radius: 8px;
    transition: border-color 0.1s;
  }
  .link-item:hover { border-color: #333; }
  .num {
    font-size: 11px;
    color: #555;
    min-width: 40px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .link-item a {
    color: #7aacf0;
    font-size: 13px;
    text-decoration: none;
    word-break: break-all;
    flex: 1;
  }
  .link-item a:hover { color: #a8c8ff; text-decoration: underline; }
  .open-btn {
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 5px;
    background: transparent;
    border: 1px solid #333;
    color: #888;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .open-btn:hover { border-color: #555; color: #ccc; }
  .warn-box {
    background: #1a1200;
    border: 1px solid #3a2d00;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 12px;
    color: #c8a840;
    margin-top: 1rem;
    display: none;
    line-height: 1.6;
  }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #111; }
  ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
</style>
</head>
<body>

<h1>URL Range Opener</h1>
<p class="subtitle">Thay đuôi link và mở hàng loạt — chạy thẳng trên trình duyệt</p>

<div class="card">
  <label>URL gốc</label>
  <input type="text" id="baseUrl" placeholder="ví dụ: http://14.225.254.182/truyen/wenku8/1/4220/" value="http://14.225.254.182/truyen/wenku8/1/4220/">

  <div class="row">
    <div>
      <label>Từ số</label>
      <input type="number" id="from" value="1" min="0">
    </div>
    <div>
      <label>Đến số</label>
      <input type="number" id="to" value="10" min="0">
    </div>
    <div>
      <label>Hậu tố (tuỳ chọn)</label>
      <input type="text" id="suffix" placeholder=".html hoặc để trống">
    </div>
  </div>

  <div class="btn-row">
    <button class="btn-primary" onclick="generate()">▶ Tạo danh sách</button>
    <button class="btn-secondary" id="openAllBtn" onclick="openAll()" style="display:none">Mở tất cả</button>
    <button class="btn-danger" id="clearBtn" onclick="clearList()" style="display:none">Xoá</button>
  </div>

  <div id="status"></div>
  <div class="warn-box" id="warnBox">
    ⚠️ Nếu tab không mở được: trình duyệt đang chặn pop-up.<br>
    Nhấn vào biểu tượng khóa/pop-up trên thanh địa chỉ → chọn <strong>Cho phép pop-up</strong> từ trang này, rồi thử lại.
  </div>
</div>

<div class="card" id="listCard" style="display:none">
  <label id="listLabel">Danh sách link</label>
  <div class="link-list" id="linkList"></div>
</div>

<script>
function buildUrl(base, num, suffix) {
  let b = base.trim().replace(/\/+$/, '');
  return b + '/' + num + (suffix || '') + '/';
}

function generate() {
  const base = document.getElementById('baseUrl').value.trim();
  const from = parseInt(document.getElementById('from').value);
  const to = parseInt(document.getElementById('to').value);
  const suffix = document.getElementById('suffix').value;

  if (!base) { alert('Vui lòng nhập URL gốc'); return; }
  if (isNaN(from) || isNaN(to) || from > to) { alert('Khoảng số không hợp lệ (Từ phải ≤ Đến)'); return; }
  if (to - from > 999) { alert('Tối đa 1000 link mỗi lần để tránh treo trình duyệt'); return; }

  const list = document.getElementById('linkList');
  list.innerHTML = '';

  for (let i = from; i <= to; i++) {
    const url = buildUrl(base, i, suffix);
    const item = document.createElement('div');
    item.className = 'link-item';
    item.innerHTML = `
      <span class="num">${i}</span>
      <a href="${url}" target="_blank" rel="noopener">${url}</a>
      <button class="open-btn" onclick="window.open('${url}','_blank')">Mở</button>
    `;
    list.appendChild(item);
  }

  const count = to - from + 1;
  const status = document.getElementById('status');
  status.innerHTML = `Đã tạo <span>${count} link</span> &nbsp;·&nbsp; ${from} → ${to}`;
  status.style.display = 'block';

  document.getElementById('openAllBtn').style.display = 'inline-block';
  document.getElementById('clearBtn').style.display = 'inline-block';
  document.getElementById('listCard').style.display = 'block';
  document.getElementById('listLabel').textContent = `Danh sách (${count} link)`;
}

function openAll() {
  const links = document.querySelectorAll('#linkList a');
  if (!links.length) return;
  document.getElementById('warnBox').style.display = 'block';
  links.forEach(a => window.open(a.href, '_blank'));
}

function clearList() {
  document.getElementById('linkList').innerHTML = '';
  document.getElementById('listCard').style.display = 'none';
  document.getElementById('openAllBtn').style.display = 'none';
  document.getElementById('clearBtn').style.display = 'none';
  document.getElementById('status').style.display = 'none';
  document.getElementById('warnBox').style.display = 'none';
}
</script>
</body>
</html>
